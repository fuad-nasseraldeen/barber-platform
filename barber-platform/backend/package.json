{
  "name": "barber-saas-platform",
  "version": "1.0.0",
  "description": "Production-grade SaaS platform for service-based businesses",
  "private": true,
  "scripts": {
    "clean": "npx rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node dist/src/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "start:prod:fresh": "npm run build && node dist/src/main.js",
    "start:pm2": "pm2 start ecosystem.config.js",
    "restart:pm2": "pm2 restart barber-backend",
    "stop:pm2": "pm2 stop barber-backend",
    "logs:pm2": "pm2 logs barber-backend",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "ts-node prisma/seed.ts",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:seed-demo": "ts-node prisma/seed-demo.ts",
    "fixture:benchmark:reset": "ts-node scripts/fixtures/reset-benchmark-fixture.ts",
    "fixture:benchmark:seed": "ts-node scripts/fixtures/seed-benchmark-fixture.ts",
    "fixture:benchmark:reseed": "npm run fixture:benchmark:reset && npm run fixture:benchmark:seed",
    "fixture:deterministic:seed": "ts-node scripts/fixtures/seed-deterministic-k6.ts",
    "fixture:deterministic:reset-and-seed": "npm run fixture:benchmark:reset && npm run fixture:deterministic:seed",
    "post-k6-checks": "ts-node scripts/post-k6-db-checks.ts",
    "k6:resolve-fixture": "ts-node scripts/k6-resolve-fixture-from-db.ts",
    "k6:verify": "node scripts/run-k6-and-post-checks.cjs",
    "k6:correctness": "node scripts/run-k6-correctness.cjs",
    "k6:race": "node scripts/run-k6-race.cjs",
    "k6:latency": "node scripts/run-k6-latency.cjs",
    "k6:latency:save": "node scripts/run-k6-latency-and-save.cjs",
    "bench:appointment-load": "node scripts/benchmark-appointment-load.cjs",
    "k6:seed-lifecycle": "node scripts/run-k6-seed-lifecycle.cjs",
    "k6:reschedule-slot-sync": "node scripts/run-k6-correctness.cjs --k6-script=k6/reschedule-slot-sync.test.js",
    "k6:cache-consistency": "node scripts/run-k6-cache-consistency.cjs",
    "k6:chaos": "node scripts/run-k6-chaos.cjs",
    "debug:time-slots-projection": "ts-node scripts/debug/debug-time-slots-projection.ts",
    "projection:health": "ts-node scripts/projection/check-projection-health.ts",
    "projection:regenerate": "ts-node scripts/projection/regenerate-time-slots.ts",
    "test:booking:invariants": "ts-node scripts/booking-tests/cli/run-invariants.ts",
    "test:booking:post-k6": "ts-node scripts/booking-tests/cli/post-k6-invariants.ts",
    "test:booking:property": "ts-node scripts/booking-tests/property/property-runner.ts",
    "test:booking:longrun": "ts-node scripts/booking-tests/longrun/longrun-runner.ts",
    "test:booking:time": "ts-node scripts/booking-tests/time/time-edge-runner.ts",
    "test:booking:all": "npm run test:booking:invariants && npm run k6:correctness && npm run k6:race && npm run k6:chaos && npm run test:booking:property && npm run test:booking:time && npm run test:booking:longrun && npm run test:booking:post-k6 && npm run k6:cache-consistency",
    "db:push": "prisma db push",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^8.0.7",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/websockets": "^10.4.22",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.25.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "google-auth-library": "^9.15.1",
    "ioredis": "^5.4.1",
    "luxon": "^3.7.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^17.4.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/luxon": "^3.7.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.2",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/passport-jwt": "^4.0.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "prisma": "^5.22.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
