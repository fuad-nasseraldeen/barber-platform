# ===========================
# DATABASE (Supabase PostgreSQL)
# ===========================
# App/runtime: Supabase pooler (Session or Transaction) — often aws-*-*.pooler.supabase.com:5432, user postgres.PROJECT_REF
# Per Prisma process: connection_limit × PM2 workers ≤ pooler pool_size. Session mode (:5432) is strict — FATAL MaxClientsInSessionMode means lower connection_limit (often 3–5), stop extra processes, or use Transaction pooler (:6543) for the app.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require&connection_limit=5&pool_timeout=20"
# One-off scripts (e.g. post-k6-checks) force a tiny pool via Prisma override; optional bump if needed:
# POST_K6_DB_CONNECTION_LIMIT=1

# Dev/staging: log every SQL with duration + requestId (from RequestContextMiddleware). Do not enable in high-volume production.
# PRISMA_LOG_QUERIES=1
# Structured JSON: BookingPerf { endpoint, durationMs, serializeMs, dbDurationMs, success, queryCount, ... } + availability_breakdown
# { totalMs, cacheMs, dbMs, busyPrepMs, filterMs, remainderMs, path, slotsTotal, ... } (join logs by requestId)
# BOOKING_PERF_LOG=1
# Slim NDJSON for hot paths only (availability/hold/booking): { type:'hot_path', endpoint, durationMs, dbDurationMs, success }
# HOT_PATH_PERF_LOG=1
# One stdout line per Redis delPattern when busting availability cache (label + ms); use with GET /appointments/metrics cacheBustDelPattern
# LOG_CACHE_BUST_PERF=1
# Console JSON per getAvailabilityDayMap: { total, redis, db, busyPrep, compute } (+ GET_AVAILABILITY_ENVELOPE in BookingService).
# LOG_AVAILABILITY_INTERNAL_TIMING=1
# Same breakdown on GET /availability as JSON header X-Availability-Timing (k6: K6_PRINT_AVAILABILITY_TIMING=1). Dev/load lab only.
# When set, body includes populated:true after the handler runs; ignore numeric fields while populated is false.
# AVAILABILITY_TIMING_RESPONSE_HEADER=1

# Prisma interactive $transaction: wait for a free pool connection (default 12s) and max tx runtime (25s).
# Raise if you see "Unable to start a transaction in the given time" under load (also: connection_limit × workers ≤ DB max).
# PRISMA_TX_MAX_WAIT_MS=20000
# PRISMA_TX_TIMEOUT_MS=30000

# PM2 cluster: schedulers (@Cron / HELD expiry) run only on NODE_APP_INSTANCE=0 (see ecosystem.config.js instance_var).
# Optional: DISABLE_SCHEDULER=1 to turn off all scheduled DB jobs on this process.
#
# REQUIRED for prisma migrate: Dashboard → Connect → "Direct connection" (db.PROJECT_REF.supabase.co:5432, user postgres)
# Without DIRECT_URL matching this, Prisma uses the pooler for migrate → P1002 advisory lock timeouts are common.
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require&connect_timeout=60"

# ===========================
# REDIS (Upstash recommended)
# ===========================
# Required for slot locks, cache, queues, OTP (unless OTP_USE_MEMORY_STORE=true).
ENABLE_REDIS=true
# Bull workers: availability regen, notifications, automation (more Redis commands/day)
ENABLE_QUEUE_WORKERS=true
REDIS_HOST=xxx.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=xxx
REDIS_TLS=true
REDIS_URL="rediss://default:PASSWORD@HOST:6379"
# Production: fail startup if Redis unreachable (default true). Dev override:
# REQUIRE_REDIS_IN_PRODUCTION=false
# If Redis is down in dev and you need OTP without Redis: OTP_USE_MEMORY_STORE=true (not for production).
# OTP_USE_MEMORY_STORE=false

# ===========================
# Supabase Storage
# ===========================
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxx
SUPABASE_BUCKET=tenant-assets
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx

# ===========================
# Google OAuth
# ===========================
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_MAPS_KEY=xxx

# ===========================
# SMS (sms.to)
# ===========================
SMS_TO_API_KEY=xxx
# Sender ID: alphanumeric + spaces only (e.g. Toren, MyBarber). Default: Toren
# SMS_SENDER_ID=SMS OTP

# ===========================
# JWT
# ===========================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# Access token: short-lived (15m). Refresh extends session.
JWT_EXPIRES_IN=15m
# Refresh token: sliding expiration. Each refresh gives new token with this duration.
# 90d = stay logged in as long as app used at least once per 90 days.
JWT_REFRESH_EXPIRES_IN=90d
# HttpOnly refresh cookie (POST /auth/refresh reads it). In dev, REFRESH_COOKIE_SECURE=false so cookie works on http://localhost.
# Production: use defaults (secure=true, sameSite=strict) or set REFRESH_COOKIE_SAME_SITE=none if SPA is on another domain (requires secure=true).
# REFRESH_COOKIE_SECURE=false
# REFRESH_COOKIE_SAME_SITE=strict

# ===========================
# Stripe
# ===========================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ===========================
# App
# ===========================
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
APP_URL=http://localhost:3000
# k6: DISABLE_BOOKING_THROTTLE=1 removes all Nest throttling (ThrottlerModule + guard). Otherwise /book uses BOOK_THROTTLE_PER_MIN (default 240/min per JWT).
# BOOK_THROTTLE_PER_MIN=240
# DISABLE_BOOKING_THROTTLE=1
# INSERT retries for transient DB errors only; same-slot contention stays 409. Default 1 = fail fast.
# BOOKING_INSERT_MAX_ATTEMPTS=1

# GET /availability read model: =1 uses materialized `time_slots` (lower latency); =0 uses computed Redis+DB path.
# Compare p95 via GET /appointments/metrics → availability.availabilityTimeSlotsPathShare and availabilityReadPath* counts.
# USE_TIME_SLOTS=0
#
# With USE_TIME_SLOTS=1 + ENABLE_REDIS=true: Redis cache-aside for the time_slots read path (no pattern bust; explicit DEL on book/hold/cancel).
# AVAILABILITY_REDIS_CACHE=1
# AVAILABILITY_TIME_SLOTS_CACHE_TTL_SEC=60
# Structured Nest log per GET (path cache_hit|cache_miss, redisMs, dbMs slot-only, tzMs).
#
# Availability: Redis + ENABLE_QUEUE_WORKERS=true + ENABLE_AVAILABILITY_WORKER=true for BullMQ precompute.
# Startup + hourly + daily UTC cron queue min(BOOKING_WINDOW_DAYS, AVAILABILITY_PRECOMPUTE_DAYS); default cap 30 days ahead.
# AVAILABILITY_PRECOMPUTE_DAYS=30
# Finer grid = more bookable anchors (default 15). Use 30 only if legacy ledger was built on 30-minute steps.
# AVAILABILITY_SLOT_INTERVAL_MINUTES=10
# AVAILABILITY_SLOT_STEP_MINUTES=5   # Spacing between offered start times (interval engine); 1|2|3|5|6|10|12|15|20|30
# (removed) AVAILABILITY_GREEDY_PACK — interval engine lists all valid starts; no greedy pack
# Max offered starts per wall-clock hour (matches slot HH:mm) per staff after grid + non-overlap (default 3). Set 0 to disable cap.
# AVAILABILITY_MAX_SLOTS_PER_HOUR=0   # 0 = no hourly cap (max slots, less herd contention); 3–6 = cap for UI density
# Invariant: if any two offered [start,start+duration) overlap → ERROR log; set =1 to throw 500 (staging).
# AVAILABILITY_STRICT_NO_OVERLAP=0
# Log slotsCount / per-hour histogram for GET /availability compute path (not cache hit).
# LOG_AVAILABILITY_SLOT_ANALYSIS=0
# Warn when offered list is sparse or hour-clustered (contention risk). Set 0 to silence.
# AVAILABILITY_LOW_ENTROPY_WARN=1
# Real-time console.log staffId + slot count on each availability compute + each GET /availability (after cache & slice). Dev/k6 only.
# LOG_AVAILABILITY_STAFF_SLOTS=1
# JSON console: busy-layer Redis HIT/MISS + computeMs for getAvailabilityDayMap; plus BookingService.getAvailability totalMs
# LOG_AVAILABILITY_CACHE_DEBUG=1
# Log full JSON array returned by GET /availability (can be large; dev/k6 only).
# LOG_AVAILABILITY_RESPONSE_JSON=1
# Log query.compact + per-day slots.length before slotsDetail (diagnose missing slotsDetail vs compact=1).
# LOG_AVAILABILITY_COMPACT_DEBUG=1
# GET /availability: Express req.query + DTO query.compact (same flag in k6 __ENV when using npm run k6:race).
# LOG_AVAILABILITY_QUERY_DEBUG=1
# After cache: one DB UNION trims offered slots vs real appointments+holds (default on; set 0 to disable).
# AVAILABILITY_READ_REPAIR=1
# Limit read-repair DB UNION to calendar days in [today, today+N] (business TZ); default 7. ALWAYS=1 = no limit.
# AVAILABILITY_READ_REPAIR_CHURN_WINDOW_DAYS=7
# AVAILABILITY_READ_REPAIR_ALWAYS=0
# Emergency switch: when false, mutation-triggered time_slots projection does not run synchronously.
# Keep false in serverless environments to avoid long request/transaction stalls.
# TIME_SLOT_PROJECTION_SYNC_ENABLED=false
# Master switch for synchronous/asynchronous time_slots projection work in request paths.
# Default behavior in code is false when unset.
# TIME_SLOT_PROJECTION_ENABLED=false
# Structured warn log on POST slot-holds 409 after assert (default on; set 0 to silence).
# LOG_AVAILABILITY_HOLD_RACE=1
# GET /availability/debug-day?staffId=&date= (owner/manager): full pipeline log in server logs; set to 1 to enable.
# AVAILABILITY_DEBUG_DAY=0
# Internal GET /availability/debug (slot-by-slot reasons). Off in production.
# AVAILABILITY_SLOT_DEBUG=0
# First day of each batch only: local working hours, bookings as local HH:mm, free minute intervals (after subtracting bookings).
# LOG_AVAILABILITY_BUSINESS_LOCAL_DEBUG=0
# Per offered slot: workingStartMin/workingEndMin + each slot's slotStartMin/slotEndMin (numeric WH check).
# LOG_AVAILABILITY_SLOT_MINUTES_DEBUG=0
# Before offered-slot validation: console.log { generatedFree, validationFree } (same ref if pipeline OK).
# LOG_AVAILABILITY_FREE_INTERVAL_PARITY=0
# Dev: throw if any free interval escapes working after subtract+clamp (catches bad busy/cache).
# AVAILABILITY_ASSERT_FREE_IN_WORKING=0
# Per booking validate: working + slot start/end in minutes (business local day).
# LOG_BOOKING_WORKING_MINUTES_DEBUG=0
# Per booking on business-local day clip: raw DB epoch ms vs minute-grid ms (+ diff ms). Catches TZ / rounding bugs.
# LOG_AVAILABILITY_BOOKING_PARSE_DIFF=0
# Per slot-hold: bizTzMs, validateMs, holdTxMs, bustCacheMs, outcome.
# LOG_SLOT_HOLD_PERF=1
# Per confirmBookingFromHold: idempotencyMs, lockMs, holdReadMs, overlapCheckMs, bizTzMs, insertConsumeMs, totalTxMs.
# LOG_BOOKING_CONFIRM_PERF=1

# ===========================
# Runtime / load stability (single Node process)
# ===========================
# Max in-flight HTTP requests before 503 (0 = disabled). Try 100–300 on laptop; tune vs DB pool + CPU.
# Single-request timeout: if handler outlives this, middleware sends 503 — but async handlers may still
# finish later and hit ERR_HTTP_HEADERS_SENT. Paths containing schedule-snapshot skip this timer (heavy report).
# HTTP_MAX_CONCURRENT_REQUESTS=0
# Hard timeout per request (ms, 0 = disabled). Node applies to inactive period on socket.
# HTTP_REQUEST_TIMEOUT_MS=0
# Event loop lag sampling (ms). Warn if tick delayed by RUNTIME_EVENT_LOOP_WARN_MS+.
# RUNTIME_EVENT_LOOP_SAMPLE_MS=5000
# RUNTIME_EVENT_LOOP_WARN_MS=100
# GET /api/v1/health/diagnostics — pid, httpInFlight, event loop lag (no DB). Local/staging only.
# ENABLE_HEALTH_DIAGNOSTICS=1
# Libuv threadpool for dns/fs/crypto (default 4). Under heavy parallel DB/crypto on one process sometimes raise to 8–16.
# UV_THREADPOOL_SIZE=8
# Legacy: full-day computed cache TTL (still recognized elsewhere if set). Layer-1 busy intervals use AVAILABILITY_BUSY_CACHE_TTL_SEC.
# AVAILABILITY_COMPUTED_CACHE_TTL_SEC=90
# Layer-1 busy intervals (bookings+holds+breaks) per staff/day key — seconds 10–120, default 30; not busted on hold create.
# AVAILABILITY_BUSY_CACHE_TTL_SEC=30
# Full-day availability result cache (per staff+service+date); clamped 30–60s, default 45.
# AVAILABILITY_DAY_FULL_CACHE_TTL_SEC=45
# Days ahead customers can book (wider = more spread for load tests / multi-week calendars).
# BOOKING_WINDOW_DAYS=90
# Worker concurrency (BullMQ jobs in parallel)
# AVAILABILITY_WORKER_CONCURRENCY=10
# Under synthetic load, set false to avoid on-demand enqueue storms (rely on cron + warm queue only)
# AVAILABILITY_ENQUEUE_ON_MISS=false
# DETERMINISTIC_AVAILABILITY (legacy): no longer disables BullMQ; prefer leaving false in production.
# Manual regen: POST api/v1/availability/regenerate with { "date": "YYYY-MM-DD" } (optional staffId).
# ENABLE_AVAILABILITY_PRECOMPUTE_CRON=false
# ENABLE_AVAILABILITY_WORKER=false
# Comma-separated origins for CORS (default: localhost:3001, localhost:3000)
# CORS_ORIGIN=http://localhost:3001,http://127.0.0.1:3001
#
# --- k6 (npm run k6:correctness) — BUSINESS_ID + AUTH_TOKEN required; STAFF_IDS,SERVICE_IDS,CUSTOMER_IDS optional if DATABASE_URL set
# BUSINESS_ID=
# AUTH_TOKEN=
# STAFF_IDS=
# SERVICE_IDS=
# CUSTOMER_IDS=
