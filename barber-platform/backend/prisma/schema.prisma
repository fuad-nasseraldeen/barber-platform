// =============================================================================
// Barbershop SaaS Platform - Production Database Schema
// Multi-tenant, UUID PKs, Soft deletes, High-performance booking
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================================================
// USERS & IDENTITY
// =============================================================================

model User {
  id             String    @id @default(uuid())
  email          String?   @unique
  emailVerified  Boolean   @default(false)
  phone          String?   @unique
  phoneVerified  Boolean   @default(false)
  passwordHash   String?
  firstName      String?
  lastName       String?
  birthDate      DateTime?
  gender         String?   // MALE, FEMALE
  avatarUrl      String?
  authProvider   String    @default("phone")
  authProviderId String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  businessUsers  BusinessUser[]
  staff          Staff?
  refreshTokens  RefreshToken[]
  notifications  Notification[]
  userSettings   UserSettings?

  @@map("users")
}

model UserSettings {
  id        String   @id @default(uuid())
  userId    String   @unique
  theme    String   @default("dark")
  locale   String   @default("en")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}


// =============================================================================
// BUSINESSES (Multi-tenant)
// =============================================================================

model Business {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  type      BusinessType @default(BARBER_SHOP)
  timezone  String   @default("UTC")
  locale    String   @default("en")
  currency  String   @default("USD")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  storageBucketId      String?
  requireEmployeeVacationApproval Boolean @default(true)
  settings   Json?    // General settings, notifications, automations config
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  locations       Location[]
  branches        Branch[]
  businessUsers   BusinessUser[]
  businessInvites BusinessInvite[]
  staffInvites    StaffInvite[]
  roles           Role[]
  services        Service[]
  serviceCategories ServiceCategory[]
  staff           Staff[]
  customers       Customer[]
  appointments    Appointment[]
  waitlists       Waitlist[]
  payments        Payment[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  subscriptions   Subscription[]
  businessHolidays BusinessHoliday[]
  dailyBusinessStats DailyBusinessStats[]
  dailyStaffStats   DailyStaffStats[]
  dailyServiceStats DailyServiceStats[]
  customerVisits    CustomerVisit[]
  automationRules   AutomationRule[]

  @@map("businesses")
}

enum BusinessType {
  BARBER_SHOP
  BEAUTY_SALON
  GYM
  CLINIC
}

model BusinessUser {
  id        String   @id @default(uuid())
  businessId String
  userId    String
  roleId    String
  isActive  Boolean  @default(true)
  invitedAt DateTime?
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([businessId, userId])
  @@index([businessId])
  @@index([userId])
  @@map("business_users")
}

model BusinessInvite {
  id         String   @id @default(uuid())
  businessId String
  email      String
  roleId     String
  token      String   @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  role     Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([businessId, email])
  @@index([token])
  @@index([businessId])
  @@map("business_invites")
}

// Staff invitation by phone - when admin adds employee by phone number
model StaffInvite {
  id         String    @id @default(uuid())
  businessId String
  branchId   String?
  phone      String
  roleId     String
  status     StaffInviteStatus @default(PENDING)
  expiresAt  DateTime
  acceptedAt DateTime?
  staffId    String?   // Set when staff completes registration
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch   Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  role     Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([businessId, phone])
  @@index([phone])
  @@index([businessId])
  @@map("staff_invites")
}

enum StaffInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

model Role {
  id          String   @id @default(uuid())
  businessId  String?
  name        String
  slug        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business        Business?        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessUsers   BusinessUser[]
  businessInvites BusinessInvite[]
  staffInvites    StaffInvite[]
  rolePermissions RolePermission[]

  @@unique([businessId, slug])
  @@index([businessId])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  resource    String
  action      String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

// =============================================================================
// BRANCHES (Physical locations per business)
// =============================================================================

model Branch {
  id         String   @id @default(uuid())
  businessId String
  name       String
  address    String?
  street     String?
  city       String?
  lat        Float?
  lng        Float?
  phone      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staff        Staff[]
  services     Service[]
  appointments Appointment[]
  waitlists    Waitlist[]
  customers    Customer[]
  customerVisits CustomerVisit[]
  staffWorkingHours StaffWorkingHours[]
  staffBreaks  StaffBreak[]
  staffBreakExceptions StaffBreakException[]
  staffTimeOff StaffTimeOff[]
  staffInvites StaffInvite[]

  @@index([businessId])
  @@map("branches")
}

// =============================================================================
// LOCATIONS (Legacy - kept for backward compatibility)
// =============================================================================

model Location {
  id         String   @id @default(uuid())
  businessId String
  name       String
  slug       String
  address    String?
  city       String?
  state      String?
  postalCode String?
  country    String   @default("US")
  latitude   Float?
  longitude  Float?
  phone      String?
  email      String?
  timezone   String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staff        Staff[]
  appointments Appointment[]

  @@unique([businessId, slug])
  @@index([businessId])
  @@map("locations")
}

// =============================================================================
// SERVICES
// =============================================================================

model ServiceCategory {
  id         String   @id @default(uuid())
  businessId String
  name       String
  slug       String
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  services Service[]

  @@unique([businessId, slug])
  @@index([businessId])
  @@map("service_categories")
}

model Service {
  id                   String   @id @default(uuid())
  businessId           String
  branchId             String?
  categoryId           String?
  name                 String
  slug                 String
  description          String?
  durationMinutes      Int
  price                Decimal  @db.Decimal(10, 2)
  currency             String   @default("USD")
  color                String?  // hex e.g. #3B82F6
  bufferBeforeMinutes  Int      @default(0)
  bufferAfterMinutes   Int      @default(0)
  isActive             Boolean  @default(true)
  sortOrder            Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  deletedAt            DateTime?

  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch        Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  category      ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  staffServices StaffService[]
  appointments  Appointment[]
  waitlists     Waitlist[]
  dailyServiceStats DailyServiceStats[]
  customerVisits CustomerVisit[]

  @@unique([businessId, branchId, slug])
  @@index([businessId])
  @@index([branchId])
  @@index([categoryId])
  @@map("services")
}

// =============================================================================
// STAFF
// =============================================================================

model Staff {
  id         String    @id @default(uuid())
  businessId String
  branchId   String?
  locationId String?
  userId     String?   @unique
  firstName  String
  lastName   String
  email      String?
  phone      String?
  birthDate  DateTime?
  gender     String?   // MALE, FEMALE
  avatarUrl  String?
  title      String?
  bio        String?
  instagram  String?
  facebook   String?
  whatsapp   String?
  isActive   Boolean   @default(true)
  monthlyTargetRevenue Decimal? @db.Decimal(12, 2)  // Revenue target per month
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch     Branch?    @relation(fields: [branchId], references: [id], onDelete: SetNull)
  location   Location?   @relation(fields: [locationId], references: [id], onDelete: SetNull)
  user       User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  staffServices         StaffService[]
  staffWorkingHours     StaffWorkingHours[]
  staffBreaks           StaffBreak[]
  staffBreakExceptions  StaffBreakException[]
  staffTimeOff          StaffTimeOff[]
  appointments         Appointment[]
  availabilityCache    StaffAvailabilityCache[]
  waitlists            Waitlist[]
  dailyStaffStats      DailyStaffStats[]
  customerVisits       CustomerVisit[]

  @@index([businessId])
  @@index([branchId])
  @@index([locationId])
  @@index([userId])
  @@map("staff")
}

model StaffService {
  id               String   @id @default(uuid())
  staffId          String
  serviceId        String
  durationMinutes Int      @default(30)
  price            Decimal  @db.Decimal(10, 2) @default(0)
  allowBooking     Boolean  @default(true)
  popupMessage     String?
  sendHealthDeclaration Boolean @default(false)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())

  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([staffId, serviceId])
  @@index([staffId])
  @@index([serviceId])
  @@map("staff_services")
}

// Recurring weekly schedule (e.g., Mon 09:00-17:00)
model StaffWorkingHours {
  id        String   @id @default(uuid())
  staffId   String
  branchId  String?
  dayOfWeek Int      // 0=Sunday, 6=Saturday
  startTime String   // "09:00" 24h
  endTime   String   // "17:00"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff  Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([staffId, dayOfWeek])
  @@index([staffId])
  @@index([branchId])
  @@map("staff_working_hours")
}

// Breaks within a shift (e.g., lunch 12:00-13:00) - weekly recurring
model StaffBreak {
  id        String   @id @default(uuid())
  staffId   String
  branchId  String?
  dayOfWeek Int
  startTime String
  endTime   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff  Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([staffId])
  @@index([staffId, dayOfWeek])
  @@index([branchId])
  @@map("staff_breaks")
}

// Date-specific breaks (one-time or date range) - multiple per day allowed
model StaffBreakException {
  id        String   @id @default(uuid())
  staffId   String
  branchId  String?
  date      DateTime @db.Date
  startTime String
  endTime   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff  Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([staffId])
  @@index([staffId, date])
  @@index([branchId])
  @@map("staff_break_exceptions")
}

// Vacation request status
enum VacationStatus {
  REQUESTED
  APPROVED
  REJECTED
  CANCELLED
}

// Time off (vacation, sick days)
model StaffTimeOff {
  id          String         @id @default(uuid())
  staffId     String
  branchId    String?
  startDate   DateTime
  endDate     DateTime
  startTime   String?        // optional, for partial-day e.g. "09:00"
  endTime     String?        // optional, for partial-day e.g. "14:00"
  reason      String?        // vacation, sick, personal
  isAllDay    Boolean        @default(true)
  status      VacationStatus @default(APPROVED) // APPROVED for manager-created; REQUESTED for employee requests
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  staff  Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([staffId])
  @@index([staffId, startDate, endDate])
  @@index([branchId])
  @@map("staff_time_off")
}

// Business-wide holidays
model BusinessHoliday {
  id         String   @id @default(uuid())
  businessId String
  date       DateTime
  name       String?
  isRecurring Boolean @default(false) // e.g., Christmas every year
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, date])
  @@index([businessId])
  @@index([businessId, date])
  @@map("business_holidays")
}

// Precomputed availability slots (one row per staff per date)
// slots: JSON array of time strings e.g. ["09:00", "09:30", "10:00"]
model StaffAvailabilityCache {
  id          String   @id @default(uuid())
  staffId     String
  date        DateTime // Date only (no time component)
  slots       Json     // ["09:00", "09:30", "10:00", ...]
  generatedAt DateTime @default(now())

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
  @@index([staffId])
  @@index([staffId, date])
  @@map("staff_availability_cache")
}

// =============================================================================
// CUSTOMERS
// =============================================================================

model Customer {
  id              String   @id @default(uuid())
  businessId      String
  branchId        String?
  email           String
  firstName       String?
  lastName        String?
  phone           String?
  birthDate       DateTime?
  gender          String?  // MALE, FEMALE, OTHER
  tagColor        String?  // hex e.g. #3B82F6
  stripeCustomerId String?
  notes           String?
  healthDeclarationCompleted Boolean @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch        Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  appointments  Appointment[]
  customerVisits CustomerVisit[]
  waitlists     Waitlist[]
  notifications Notification[]
  payments      Payment[]
  loyaltyPoints LoyaltyPoints?
  customerNotes CustomerNote[]

  @@unique([businessId, email])
  @@index([businessId])
  @@index([branchId])
  @@index([businessId, email])
  @@index([phone])
  @@map("customers")
}

model CustomerNote {
  id         String   @id @default(uuid())
  customerId String
  note       String
  createdBy  String?  // userId
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([customerId, createdAt])
  @@map("customer_notes")
}

model LoyaltyPoints {
  id         String   @id @default(uuid())
  customerId String   @unique
  points     Int      @default(0)
  lifetimeEarned Int  @default(0)
  lifetimeRedeemed Int @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("loyalty_points")
}

// =============================================================================
// APPOINTMENTS (Booking Engine)
// =============================================================================

model Appointment {
  id              String          @id @default(uuid())
  businessId      String
  branchId        String?
  locationId      String?
  customerId      String
  staffId         String
  serviceId       String
  startTime       DateTime
  endTime         DateTime
  status          AppointmentStatus @default(PENDING)
  slotKey         String          @unique // businessId:staffId:YYYY-MM-DD:HH:mm
  notes           String?
  internalNotes   String?
  paymentId       String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  cancelledAt     DateTime?
  cancellationReason String?

  business Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch   Branch?    @relation(fields: [branchId], references: [id], onDelete: SetNull)
  location Location?  @relation(fields: [locationId], references: [id], onDelete: SetNull)
  customer Customer   @relation(fields: [customerId], references: [id], onDelete: Restrict)
  staff    Staff       @relation(fields: [staffId], references: [id], onDelete: Restrict)
  service  Service    @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  payment  Payment?
  appointmentSlots AppointmentSlot[]
  customerVisit  CustomerVisit?

  @@index([businessId])
  @@index([branchId])
  @@index([businessId, startTime])
  @@index([businessId, status])
  @@index([customerId])
  @@index([staffId])
  @@index([staffId, startTime, endTime])
  @@index([slotKey])
  @@map("appointments")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

// =============================================================================
// CUSTOMER VISITS (CRM & Analytics)
// =============================================================================

model CustomerVisit {
  id            String   @id @default(uuid())
  businessId    String
  branchId      String?
  customerId    String
  staffId       String
  serviceId     String
  appointmentId String   @unique
  visitDate     DateTime
  status        CustomerVisitStatus
  price         Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch   Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  staff    Staff    @relation(fields: [staffId], references: [id], onDelete: Restrict)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([customerId])
  @@index([staffId])
  @@index([branchId])
  @@index([visitDate])
  @@index([businessId, visitDate])
  @@map("customer_visits")
}

enum CustomerVisitStatus {
  COMPLETED
  NO_SHOW
  CANCELLED
}

// =============================================================================
// AUTOMATION RULES (Visit-based conditions)
// =============================================================================

model AutomationRule {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  isActive    Boolean  @default(true)
  triggerType String   // e.g. 'visit_created', 'scheduled'
  conditions  Json     // [{ type, operator, value }]
  actions     Json?    // [{ type, config }] - e.g. send_notification
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, isActive])
  @@map("automation_rules")
}

// Slot locking for concurrent booking
model AppointmentSlot {
  id        String   @id @default(uuid())
  appointmentId String
  slotKey   String   @unique
  businessId String
  staffId   String
  slotTime  DateTime
  expiresAt DateTime
  createdAt DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([businessId, slotTime])
  @@index([expiresAt])
  @@map("appointment_slots")
}

// =============================================================================
// WAITLIST
// =============================================================================

model Waitlist {
  id                 String        @id @default(uuid())
  businessId         String
  branchId           String?
  customerId         String
  serviceId          String
  staffId            String?
  locationId         String?
  preferredDateStart DateTime?
  preferredDateEnd   DateTime?
  preferredTimeStart String?
  preferredTimeEnd   String?
  priority           Int           @default(0)  // Higher = sooner in line
  status             WaitlistStatus @default(ACTIVE)
  notes              String?
  notifiedAt         DateTime?
  notifiedSessionId  String?       // Redis lock sessionId for NOTIFIED slot
  notifiedStaffId    String?       // For releasing lock on expiry
  notifiedDate       String?       // YYYY-MM-DD
  notifiedStartTime  String?       // HH:mm
  expiresAt          DateTime?     // When NOTIFIED slot reservation expires
  convertedToAppointmentId String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch   Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  staff    Staff?   @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([branchId])
  @@index([businessId, status])
  @@index([customerId])
  @@index([serviceId])
  @@index([staffId])
  @@index([expiresAt])
  @@map("waitlist")
}

enum WaitlistStatus {
  ACTIVE
  NOTIFIED
  CONVERTED
  CANCELLED
}

// =============================================================================
// PAYMENTS
// =============================================================================

model Payment {
  id                    String        @id @default(uuid())
  businessId             String
  customerId             String?
  appointmentId         String?       @unique
  amount                 Decimal       @db.Decimal(10, 2)
  currency               String        @default("USD")
  type                   PaymentType   @default(FULL)
  status                 PaymentStatus @default(PENDING)
  stripePaymentIntentId  String?
  stripeChargeId         String?
  metadata               Json?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer    Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([stripePaymentIntentId])
  @@map("payments")
}

enum PaymentType {
  DEPOSIT
  FULL
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELLED
}

model Subscription {
  id                    String            @id @default(uuid())
  businessId            String
  stripeSubscriptionId  String?           @unique
  stripePriceId         String?
  stripeCustomerId      String?
  status                SubscriptionStatus @default(ACTIVE)
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  planId                String?
  metadata              Json?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([stripeSubscriptionId])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

// =============================================================================
// NOTIFICATIONS & AUDIT
// =============================================================================

model Notification {
  id          String   @id @default(uuid())
  businessId  String
  userId      String?
  customerId  String?
  type        String
  title       String
  body        String?
  data        Json?
  channel     NotificationChannel @default(IN_APP)
  readAt      DateTime?
  sentAt      DateTime?
  createdAt   DateTime @default(now())

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, createdAt])
  @@index([userId])
  @@index([customerId])
  @@index([userId, readAt])
  @@map("notifications")
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  PUSH
}

model AuditLog {
  id         String   @id @default(uuid())
  businessId String
  userId    String?
  action    String
  resource  String
  resourceId String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, createdAt])
  @@index([resource, resourceId])
  @@map("audit_logs")
}

// =============================================================================
// ANALYTICS AGGREGATION TABLES (Precomputed daily stats)
// =============================================================================

model DailyBusinessStats {
  id         String   @id @default(uuid())
  businessId String
  date       DateTime
  totalAppointments Int @default(0)
  completedAppointments Int @default(0)
  cancelledAppointments Int @default(0)
  noShowAppointments Int @default(0)
  totalRevenue Decimal @db.Decimal(12, 2) @default(0)
  newCustomers Int @default(0)
  waitlistCount Int @default(0)
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, date])
  @@index([businessId])
  @@index([businessId, date])
  @@map("daily_business_stats")
}

model DailyStaffStats {
  id         String   @id @default(uuid())
  businessId String
  staffId    String
  date       DateTime
  totalBookings Int @default(0)
  completedBookings Int @default(0)
  cancelledBookings Int @default(0)
  revenue   Decimal @db.Decimal(12, 2) @default(0)
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staff    Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([businessId, staffId, date])
  @@index([businessId])
  @@index([businessId, date])
  @@index([staffId, date])
  @@map("daily_staff_stats")
}

model DailyServiceStats {
  id         String   @id @default(uuid())
  businessId String
  serviceId  String
  date       DateTime
  bookingCount Int @default(0)
  revenue   Decimal @db.Decimal(12, 2) @default(0)
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([businessId, serviceId, date])
  @@index([businessId])
  @@index([businessId, date])
  @@index([serviceId, date])
  @@map("daily_service_stats")
}
